# Azure PII Container
PII_CONTAINER_ENDPOINT="http://localhost:5000"
PII_API_KEY="your-azure-language-api-key"

# Azure OpenAI (for future agent integration)
AZURE_OPENAI_API_KEY="your-azure-openai-key"
AZURE_OPENAI_ENDPOINT="https://your-instance.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4"

# Legacy Foundry IQ lane
AZURE_AI_FOUNDRY_BASE_URL="https://your-legacy-foundry-resource.services.ai.azure.com"
AZURE_AI_FOUNDRY_PROJECT="your-legacy-foundry-project"

# Separate Fabric IQ lane
FABRIC_IQ_FOUNDRY_BASE_URL="https://your-fabric-foundry-resource.services.ai.azure.com"
FABRIC_IQ_FOUNDRY_PROJECT="admin-4912"
FABRIC_IQ_AGENT_NAME="af-funds-fabric-agent"

# Separate RTI / IQ lane
NEXT_PUBLIC_ENABLE_RTI_IQ="false"
RTI_IQ_FOUNDRY_BASE_URL="https://your-rti-foundry-resource.services.ai.azure.com"
RTI_IQ_FOUNDRY_PROJECT="admin-4912"
RTI_IQ_AGENT_NAME="af-funds-rti-iq-agent"

# Auth (placeholder for NextAuth)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
